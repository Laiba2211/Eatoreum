MONGO_URI=mongodb://127.0.0.1:27017/eatoreum
PORT=5000

# --- Redis (optional but recommended at scale) ---
# If set, hot read paths are cached: GET /api/products, /api/products/:id, /api/categories
# Cache is cleared when admin creates/updates/deletes a product or creates a category.
# Lazy client: config/redis.js + utils/redisCache.js (comment next line to disable Redis)
REDIS_URL=redis://127.0.0.1:6379
# TTL in seconds for cached JSON (default 60, max 3600)
REDIS_CACHE_TTL_SEC=60
#
# Production: Redis is not “mandatory” for every app, but it is the standard choice for:
# - Response caching (what we wired here) to cut MongoDB load on catalog traffic
# - Rate limiting counters across multiple API instances (add middleware when you scale out)
# - Session / token blocklists if you move beyond stateless JWT
# - Job queues (BullMQ) for emails and async work
# Use a managed Redis (AWS ElastiCache, Redis Cloud, Upstash) with TLS in production.

# Admin JWT (required for login + /me)
JWT_SECRET=change-this-to-a-long-random-string
JWT_EXPIRES_IN=7d

# Used by: npm run seed:admin (ADMIN_EMAIL + ADMIN_PASSWORD required)
ADMIN_EMAIL=admin@eatoreum.local
ADMIN_PASSWORD=admin123
ADMIN_NAME=Super Admin
ADMIN_ROLE=superadmin

# --- Nodemailer (order emails + public POST /api/contact → SMTP_USER, Reply-To visitor) ---
# Gmail: use an App Password (Google Account → Security → 2-Step → App passwords), not your normal password.
# Leave SMTP_HOST empty to skip sending mail (order API still works).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
# Shop inbox: receives a separate “new order” email (not the customer template). Shoppers still get their own confirmation when they provide an email.
SMTP_USER=your.email@gmail.com
SMTP_PASS=your-16-char-app-password
# Optional; defaults to "Eatoreum <SMTP_USER>"
# MAIL_FROM=Eatoreum <your.email@gmail.com>
# Optional link in the customer email footer + newsletter welcome email
# STORE_PUBLIC_URL=http://localhost:5173

# Newsletter footer signup (POST /api/newsletter/subscribe). Uses SMTP_* to send.
# Optional: inbox for “new subscriber” alerts (defaults to SMTP_USER if unset)
# NEWSLETTER_NOTIFY_EMAIL=your.email@gmail.com
# Optional “Open in admin” button in the shop order email (no trailing slash)
# ADMIN_APP_URL=http://localhost:5174
